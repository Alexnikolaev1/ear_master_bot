# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Ключ Google Gemini API (бесплатный тариф) https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Ключ Groq API (бесплатный тариф, Whisper) https://console.groq.com/keys
GROQ_API_KEY=

# Публичный URL приложения на Railway для вебхука Telegram.
# Вариант 1: сгенерируйте домен в Railway → Networking → Generate Domain
# и укажите его здесь БЕЗ https://, например:
# WEBHOOK_HOST=ear-master-bot-production.up.railway.app
# Вариант 2: удалите WEBHOOK_HOST — бот возьмёт RAILWAY_PUBLIC_DOMAIN автоматически.
# НЕ используйте *.railway.internal — это внутренняя сеть Railway, Telegram туда не ходит.
WEBHOOK_HOST=

# Порт, который слушает aiohttp-сервер (Railway передаёт его в переменной PORT)
PORT=8080

# Секретный путь вебхука (можно оставить как есть либо сгенерировать свой)
WEBHOOK_SECRET=change_me_secret_path

# Часовой пояс по умолчанию для напоминаний о тренировках
DEFAULT_TIMEZONE=Europe/Moscow

# Каталог временных файлов (опционально; по умолчанию /tmp или системный temp)
# TMP_DIR=
